doctype html
html(lang='en')
  head
    meta(charset='UTF-8')
    meta(name='viewport', content='width=device-width, initial-scale=1.0')
    meta(http-equiv='X-UA-Compatible', content='IE=edge')
    title= subject
  body(style='margin:0; padding:0; background-color:#1a1a1a; font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;')
    //- preheader (hidden preview text)
    div(style='display:none; max-height:0; overflow:hidden; opacity:0;')
      | #{senderName} sent you a message on Poking App — open the app to reply.

    table(role='presentation', width='100%', cellpadding='0', cellspacing='0', style='background-color:#1a1a1a; padding:32px 12px;')
      tbody
        tr
          td(align='center')
            table(role='presentation', width='100%', cellpadding='0', cellspacing='0', style='max-width:520px; background-color:#2c2c2c; border-radius:16px; overflow:hidden; box-shadow:0 8px 30px rgba(0,0,0,0.4);')
              tbody
                //- Brand header
                tr
                  td(style='background: linear-gradient(135deg,#9837F9,#6a1fc0); padding:28px 32px; text-align:center;')
                    span(style='font-size:22px; font-weight:700; color:#ffffff; letter-spacing:0.3px;') 💬 Poking App

                //- Body
                tr
                  td(style='padding:36px 32px 8px 32px; color:#f5f5f5;')
                    p(style='margin:0 0 8px 0; font-size:15px; color:#bbbbbb;') Hi #{name},
                    h1(style='margin:0 0 16px 0; font-size:24px; font-weight:700; color:#ffffff; line-height:1.3;')
                      | You have a new message
                    p(style='margin:0 0 24px 0; font-size:16px; line-height:1.6; color:#dddddd;')
                      strong(style='color:#c286ff;') #{senderName}
                      |  sent you a message while you were offline. Open Poking App to read it and reply.

                    //- CTA button
                    table(role='presentation', cellpadding='0', cellspacing='0', style='margin:8px 0 28px 0;')
                      tbody
                        tr
                          td(align='center', bgcolor='#9837F9', style='border-radius:10px;')
                            a(href=appUrl, target='_blank', style='display:inline-block; padding:14px 36px; font-size:16px; font-weight:700; color:#ffffff; text-decoration:none; border-radius:10px;')
                              | Open Poking App

                    p(style='margin:0; font-size:13px; line-height:1.6; color:#888888;')
                      | 🔒 For your privacy we don't include the message text in this email.

                //- Footer
                tr
                  td(style='padding:24px 32px 32px 32px; border-top:1px solid #3a3a3a;')
                    p(style='margin:0; font-size:12px; line-height:1.6; color:#777777;')
                      | You're receiving this because someone messaged you on Poking App while you were offline.
                      | To avoid spam, we send at most one of these every few hours.
            //- end card

            p(style='max-width:520px; margin:20px auto 0 auto; font-size:11px; color:#555555; text-align:center;')
              | Poking App · Sent with care 💜
